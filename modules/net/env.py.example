"""net 模块环境配置示例 — 复制到 env.py 后修改"""

# SSH 服务器地址，三种格式均可:
#   "dev"                       — SSH alias（需 ~/.ssh/config 配置，端口也在其中定义）
#   "build@192.168.1.100"       — user@ip（无需 ~/.ssh/config）
#   "192.168.1.100"             — 纯 ip（用当前系统用户名）
SSH_HOST = "dev"
SSH_PORT = 22                # 可选，默认 22。alias 格式下此值被忽略（端口由 ~/.ssh/config 决定）
